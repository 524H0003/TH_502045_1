<!DOCTYPE html>
<html lang="vi">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>@ViewData["Title"] - BenThanh Metro Smart Ticketing</title>
		<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
			rel="stylesheet" />
	</head>
	<body class="m-0">
		<div class="min-vh-100 d-flex flex-column">
			<header class="bg-primary text-white shadow-sm">
				<div
					class="container-fluid d-flex align-items-center justify-content-between py-3 px-4">
					<a
						class="d-flex align-items-center gap-3 text-decoration-none text-white"
						style="cursor: pointer">
						<div
							class="rounded-circle d-flex align-items-center justify-content-center bg-white bg-opacity-25"
							style="width: 3rem; height: 3rem">
							<i class="fa-solid fa-train-subway text-white fs-5"></i>
						</div>
						<div>
							<h1 class="fs-5 fw-bold m-0">Metro TPHCM</h1>
							<small
								class="text-white text-opacity-75"
								style="font-size: 0.8rem">
								Hệ thống mua vé tàu điện
							</small>
						</div>
					</a>
				</div>
			</header>
			<div class="bg-white border-bottom py-3">
				<div class="container">
					<div class="d-flex align-items-center justify-content-center gap-2">
						<div class="d-flex align-items-center gap-2">
							<div class="d-flex align-items-center gap-2">
								<div
									class="rounded-circle d-flex align-items-center justify-content-center fw-bold bg-primary text-white"
									style="width: 2rem; height: 2rem; font-size: 0.85rem">
									1
								</div>
								<span
									class="fw-semibold text-primary"
									style="font-size: 0.9rem">
									Chọn ga
								</span>
							</div>
							<div
								class="mx-2 bg-secondary bg-opacity-25"
								style="width: 3rem; height: 2px"></div>
						</div>
						<div class="d-flex align-items-center gap-2">
							<div class="d-flex align-items-center gap-2">
								<div
									class="rounded-circle d-flex align-items-center justify-content-center fw-bold bg-light text-secondary border"
									style="width: 2rem; height: 2rem; font-size: 0.85rem">
									2
								</div>
								<span
									class="fw-semibold text-secondary"
									style="font-size: 0.9rem">
									Thanh toán
								</span>
							</div>
							<div
								class="mx-2 bg-secondary bg-opacity-25"
								style="width: 3rem; height: 2px"></div>
						</div>
						<div class="d-flex align-items-center gap-2">
							<div class="d-flex align-items-center gap-2">
								<div
									class="rounded-circle d-flex align-items-center justify-content-center fw-bold bg-light text-secondary border"
									style="width: 2rem; height: 2rem; font-size: 0.85rem">
									3
								</div>
								<span
									class="fw-semibold text-secondary"
									style="font-size: 0.9rem">
									Hoàn tất
								</span>
							</div>
						</div>
					</div>
				</div>
			</div>
			<main class="flex-grow-1 py-4">
				<div class="container" style="max-width: 800px">@RenderBody()</div>
			</main>
			<footer class="bg-white border-top py-3">
				<div class="container text-center">
					<small class="text-muted">
						© 2026 Metro TPHCM — Hệ thống mua vé tàu điện
					</small>
				</div>
			</footer>
		</div>

		<script src="~/lib/jquery/dist/jquery.min.js"></script>
		<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
		@await RenderSectionAsync("Scripts", required: false)
	</body>
</html>
