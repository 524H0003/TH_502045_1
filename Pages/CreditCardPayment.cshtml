@page
@model TH_502045_1.Pages.CreditCardPaymentModel
@{
    ViewData["Title"] = "Thanh toán Thẻ tín dụng";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                <i class="fa-solid fa-credit-card text-primary"></i>Thanh toán thẻ tín dụng
            </h5>

            <div class="p-3 rounded mb-4 text-center" style="background:linear-gradient(135deg,#e8f4ff,#f0f4ff)">
                <div class="text-muted" style="font-size:0.85rem">Tổng tiền</div>
                <div class="fw-bold text-primary fs-3">
                    @Model.TotalAmount.ToString("N0") VND
                </div>
                <div class="text-muted" style="font-size:0.8rem">
                    @Model.DestinationName (Số lượng: @Model.Quantity)
                </div>
            </div>

            <div class="text-center">
                <div id="instructionArea">
                    <div class="mx-auto mb-4 position-relative d-inline-block">
                        <div class="rounded-3 border border-3 border-primary d-flex flex-column align-items-center justify-content-center" 
                             style="width:200px;height:140px;background:#f8f9fa">
                            <i class="fa-solid fa-credit-card text-primary" style="font-size:3rem"></i>
                            <div class="mt-2 px-4 py-1 rounded" 
                                 style="height:6px;width:140px;background:repeating-linear-gradient(90deg,#0057b8 0px,#0057b8 8px,transparent 8px,transparent 12px)">
                            </div>
                        </div>
                        <div class="position-absolute bottom-0 start-50 translate-middle-x" style="margin-bottom:-1.5rem">
                            <i class="fa-solid fa-arrow-down text-primary fa-bounce fs-4"></i>
                        </div>
                    </div>

                    <div class="mt-5">
                        <h6 class="fw-bold mb-2">Vui lòng đưa thẻ vào đầu đọc</h6>
                        <p class="text-muted mb-4" style="font-size:0.9rem">
                            Đặt thẻ Visa / Mastercard / JCB vào khe đọc thẻ bên dưới màn hình
                        </p>
                        
                        <form method="post" asp-page-handler="Process" id="paymentForm">
                            <button class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm fw-bold" type="submit" id="btnSimulate">
                                <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>GIẢ LẬP ĐƯA THẺ VÀO
                            </button>
                        </form>
                    </div>
                </div>

                <div id="processingArea" style="display: none">
                    <div class="spinner-border text-primary my-4" role="status" style="width: 4rem; height: 4rem">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <h5 class="fw-bold text-primary">ĐANG XÁC THỰC GIAO DỊCH...</h5>
                    <p class="text-muted">Vui lòng không rút thẻ ra khỏi máy.</p>
                </div>

                <div class="mt-3">
                    <a asp-page="./SelectPayment" class="btn btn-link text-decoration-none text-muted small">
                        Hủy bỏ giao dịch
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#paymentForm").submit(function () {
                // Ẩn hướng dẫn và hiện spinner khi nhấn nút
                $("#instructionArea").hide();
                $("#processingArea").show();
            });
        });
    </script>
}
