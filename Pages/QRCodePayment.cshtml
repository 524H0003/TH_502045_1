@page
@model TH_502045_1.Pages.QRCodePaymentModel
@{
    ViewData["Title"] = "Thanh toán QR Code";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                <i class="fa-solid fa-qrcode text-primary"></i>Quét mã QR để thanh toán
            </h5>

            <div class="p-3 rounded mb-4 text-center" style="background:linear-gradient(135deg,#e8f4ff,#f0f4ff)">
                <div class="text-muted" style="font-size:0.85rem">Tổng tiền</div>
                <div class="fw-bold text-primary fs-3">
                    @Model.TotalAmount.ToString("N0") VND
                </div>
                <div class="text-muted" style="font-size:0.8rem">
                    @Model.DestinationName (Số lượng: @Model.Quantity)
                </div>
            </div>

            <div class="text-center">
                <p class="text-muted mb-3" style="font-size:0.9rem">
                    Mở ứng dụng ví điện tử và quét mã bên dưới
                </p>
                
                <div class="d-inline-block p-3 border border-2 border-primary rounded-3 mb-3 bg-white" id="qrBox">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=TicketPayment_@Model.TotalAmount" 
                         alt="QR Code Thanh Toán" 
                         style="display: block; width: 180px; height: 180px;" />
                </div>

                <div class="progress mb-2 mx-auto" style="height: 6px; max-width: 250px;">
                    <div id="paymentTimer" 
                         class="progress-bar progress-bar-striped progress-bar-animated" 
                         role="progressbar" 
                         style="width: 100%"></div>
                </div>
                <p class="small text-muted mb-4">
                    Giao dịch hết hạn sau <span id="timeLeft" class="fw-bold text-danger">60</span> giây
                </p>

                <div class="d-flex flex-column gap-2">
                    <form method="post" asp-page-handler="Confirm">
                        <button type="submit" class="btn btn-primary rounded-pill w-100 py-3 fw-bold shadow-sm">
                            <i class="fa-solid fa-check-circle me-2"></i>XÁC NHẬN ĐÃ QUÉT MÃ
                        </button>
                    </form>
                    
                    <a asp-page="./SelectPayment" class="btn btn-outline-secondary rounded-pill w-100 py-2 border-0">
                        Hủy giao dịch
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            let timeLeft = 60;
            let totalTime = 60;
            let timer = setInterval(function () {
                timeLeft--;
                $("#timeLeft").text(timeLeft);
                
                // Cập nhật thanh progress
                let progressWidth = (timeLeft / totalTime) * 100;
                $("#paymentTimer").css("width", progressWidth + "%");

                if (timeLeft <= 0) {
                    clearInterval(timer);
                    alert("Giao dịch đã hết hạn!");
                    window.location.href = "./Index";
                }
            }, 1000);
        });
    </script>
}
