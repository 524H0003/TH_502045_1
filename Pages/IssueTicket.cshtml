@page
@model TH_502045_1.Pages.IssueTicketModel
@{
    ViewData["Title"] = "Phát hành vé";
}

<div class="container mt-5" style="max-width: 600px;">
    <div id="printingStatus" class="text-center">
        <div class="spinner-grow text-success" role="status" style="width: 4rem; height: 4rem"></div>
        <h2 class="mt-4 fw-bold text-success">ĐANG IN VÉ...</h2>
        <p class="text-muted">Vui lòng đợi trong giây lát và nhận vé tại khe bên dưới.</p>
    </div>

    <div id="ticketResult" style="display: none">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body p-4 p-md-5">
                <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4" style="width:5rem;height:5rem">
                    <i class="fa-solid fa-circle-check text-success" style="font-size:2.5rem"></i>
                </div>
                
                <h3 class="fw-bold text-success mb-2">Mua vé thành công!</h3>
                <p class="text-muted mb-4">Vé của bạn đã được xác nhận. Vui lòng nhận vé cứng tại khe máy.</p>

                <div class="p-4 rounded mb-4 mx-auto" style="background:#f8f9fa; max-width:420px">
                    <div class="mb-3">
                        <small class="text-muted text-uppercase">Mã vé</small>
                        <div class="fw-bold fs-3 text-primary font-monospace">@Model.Barcode</div>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Số lượng</span>
                        <span class="fw-semibold">@Model.TicketQty vé</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tổng tiền</span>
                        <span class="fw-bold text-primary fs-5">@Model.TotalPaid.ToString("N0") VND</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Thời gian</span>
                        <span class="fw-semibold">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>

                <a asp-page="./Index" class="btn btn-primary rounded-pill px-5 py-3 shadow-sm d-inline-flex align-items-center gap-2 fw-bold">
                    <i class="fa-solid fa-rotate"></i> KẾT THÚC / MUA VÉ MỚI
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Giả lập thời gian in vé vật lý (3 giây)
            setTimeout(function () {
                $("#printingStatus").fadeOut(500, function () {
                    $("#ticketResult").fadeIn(1000);
                });
            }, 3000);
        });
    </script>
}