@page
@model TH_502045_1.Pages.SelectPaymentModel
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container text-center mt-5">
	<div class="alert alert-dark shadow">
		<h2 class="fw-bold">XÁC NHẬN VÉ METRO: @Model.Destication</h2>
		<hr />
		<div class="row fs-4">
			<div class="col-6 text-end">Giá đơn vị:</div>
			<div class="col-6 text-start text-primary">
				<span id="unitPrice">@Model.UnitPrice</span> VNĐ
			</div>
		</div>
	</div>

	<div class="card my-4 border-0 shadow-sm">
		<div class="card-body bg-light">
			<h4 class="mb-3 text-uppercase">Số lượng vé</h4>
			<div class="d-flex justify-content-center align-items-center">
				<button
					type="button"
					class="btn btn-danger btn-lg rounded-circle btn-update"
					data-type="minus"
				>
					<i class="bi bi-dash-lg"></i>
				</button>

				<input
					type="number"
					id="quantityInput"
					asp-for="Quantity"
					class="form-control mx-4 text-center fw-bold fs-2"
					style="width: 120px; border: 3px solid #0d6efd"
					readonly
				/>

				<button
					type="button"
					class="btn btn-success btn-lg rounded-circle btn-update"
					data-type="plus"
				>
					<i class="bi bi-plus-lg"></i>
				</button>
			</div>
		</div>
	</div>

	<div class="mb-5">
		<h3 class="text-muted">Tổng thanh toán:</h3>
		<h1 class="display-3 fw-bold text-danger">
			<span id="totalDisplay">@Model.TotalAmount.ToString("N0")</span>
			<small>VNĐ</small>
		</h1>
	</div>

	<div class="row g-4">
		<div class="col-md-6">
			<form method="post">
				<input type="hidden" name="paymentMethod" value="CreditCard" />
				<input type="hidden" name="Quantity" class="final-qty" value="1" />
				<button
					type="submit"
					class="btn btn-outline-dark w-100 py-4 fs-3 shadow"
				>
					<i class="bi bi-credit-card"></i> THẺ TÍN DỤNG
				</button>
			</form>
		</div>
		<div class="col-md-6">
			<form method="post">
				<input type="hidden" name="paymentMethod" value="QRCode" />
				<input type="hidden" name="Quantity" class="final-qty" value="1" />
				<button
					type="submit"
					class="btn btn-outline-primary w-100 py-4 fs-3 shadow"
				>
					<i class="bi bi-qr-code"></i> QUÉT MÃ QR
				</button>
			</form>
		</div>
	</div>
</div>

@section Scripts {
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
	$(document).ready(function () {
		// Lấy giá vé đơn vị từ Model (xóa dấu phân cách nếu có)
		const unitPrice = parseInt($("#unitPrice").text().replace(/,/g, ""));

		$(".btn-update").click(function () {
			let type = $(this).data("type");
			let input = $("#quantityInput");
			let currentQty = parseInt(input.val());
			let newQty = currentQty;

			if (type === "plus" && currentQty < 10) {
				newQty = currentQty + 1;
			} else if (type === "minus" && currentQty > 1) {
				newQty = currentQty - 1;
			}

			// 1. Cập nhật giá trị hiển thị ở input
			input.val(newQty);

			// 2. Cập nhật các input ẩn trong form để gửi về Server
			$(".final-qty").val(newQty);

			// 3. Tính toán và hiển thị tổng tiền mới (Response Time tối ưu)
			let total = newQty * unitPrice;
			$("#totalDisplay").text(total.toLocaleString("vi-VN"));

			// Hiệu ứng nhẹ khi thay đổi số tiền
			$("#totalDisplay").fadeOut(100).fadeIn(100);
		});
	});
</script>
}
